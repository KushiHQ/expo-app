{
	"cli": {
		"version": ">= 16.28.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal"
		},
		"preview": {
			"distribution": "internal"
		},
		"production": {
			"node": "22.14.0",
			"autoIncrement": true,
			"android": {
				"buildType": "app-bundle"
			}
		}
	},
	"submit": {
		"production": {
			"android": {
				"serviceAccountKeyPath": "./google-play-key.json",
				"track": "internal",
				"releaseStatus": "draft"
			}
		}
	}
}
